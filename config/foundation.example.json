{
  "foundation_version": "0.3.0",
  "session_modes": {
    "default_mode": "assistant",
    "front_gate_skill": "request-mode-gate",
    "shared_decision_contract": "./contracts/session-mode-decision.schema.json",
    "company_mode": {
      "activation_policy": "request_scoped_fail_closed",
      "allow_sticky_task_resume": true,
      "require_company_operation_kind": true,
      "require_business_execution": true,
      "require_line_ownership": true,
      "deny_for_general_chat": true,
      "deny_for_meta_foundation": true,
      "deny_for_private_help_without_line_owner": true
    }
  },
  "company": {
    "control_tower": {
      "runtime_owner": "main_session",
      "spawn_as_agent": false,
      "execution_policy": "non-executing",
      "allowed_actions": [
        "dispatch",
        "request_meeting",
        "close_task",
        "escalate"
      ]
    }
  },
  "deployment": {
    "default_home": "~/.gency",
    "home_env": "GENCY_HOME",
    "optional_env_overrides": {
      "deployment_manifest": "GENCY_DEPLOYMENT_MANIFEST",
      "manifest_root": "GENCY_MANIFEST_ROOT",
      "prompt_root": "GENCY_PROMPT_ROOT",
      "state_root": "GENCY_STATE_ROOT",
      "lines_root": "GENCY_LINES_ROOT",
      "registry_root": "GENCY_REGISTRY_ROOT"
    },
    "defaults": {
      "manifest_root": "~/.gency/line-packs",
      "prompt_root": "~/.gency/prompt-packs",
      "state_root": "~/.gency/state",
      "lines_root": "~/.gency/state/lines",
      "registry_root": "~/.gency/state/registry"
    }
  },
  "lines": {
    "instantiation_mode": "external_workdir",
    "definition_source": "external_line_packs",
    "cross_line_policy": "deny"
  },
  "role_source": {
    "upstream": "agency-agents",
    "adapter_template": "./prompts/agency-role-adapter.template.md",
    "preserve_upstream_identity": true,
    "add_openclaw_constraints": true
  },
  "meetings": {
    "enabled": true,
    "same_line_only": true,
    "default_round_limit": 3,
    "minutes_format": "markdown"
  }
}
